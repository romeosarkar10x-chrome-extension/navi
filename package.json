{
    "name": "navi",
    "author": "Romeo Sarkar",
    "description": "AI-powered browser copilot sidebar",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "format:check": "prettier \"**/*.{ts,tsx,css,json,yml,yaml,md}\" --check --debug-check --ignore-path .prettierignore",
        "format": "prettier \"**/*.{ts,tsx,css,json,yml,yaml,md}\" --write --ignore-path .prettierignore",
        "lint": "eslint --flag unstable_native_nodejs_ts_config .",
        "type-check": "tsc -p tsconfig.json",
        "dev": "wxt",
        "dev:firefox": "wxt -b firefox",
        "build": "wxt build",
        "build:firefox": "wxt build -b firefox",
        "zip": "wxt zip",
        "zip:firefox": "wxt zip -b firefox",
        "compile": "tsc --noEmit",
        "postinstall": "wxt prepare"
    },
    "dependencies": {
        "openai": "^6.44.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-icons": "^5.6.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@tailwindcss/vite": "^4.3.1",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@wxt-dev/module-react": "^1.1.5",
        "eslint": "^10.5.0",
        "globals": "^17.6.0",
        "prettier": "^3.8.4",
        "tailwindcss": "^4.3.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.61.1",
        "wxt": "^0.20.26"
    }
}
